#!/bin/bash
set -efu +o posix

cd "$HOME/src/kernel-image"
list_branches() {
	local format="${1-}%(refname)"
	git branch -r --sort=-committerdate --format="$format" |
		grep '\brefs/remotes/gears/' |
		grep -v '\brefs/remotes/gears/source-' |
		grep -v '\brefs/remotes/gears/.*/HEAD' |
		sed 's!\brefs/remotes/!!'
}

pathspec=( "config*" )
unset show_unmatched show_tag print_matches re print_patch_id update_gears
for o do
	shift
	case "$o" in
		--help)
			echo >&2 "Use git log options such as -G / --shortstat / --numstat"
			exit 1
			;;
		-l|--list) list_branches '%(creatordate:short) '; exit ;;
		--spec) pathspec=( 'kernel-image.spec' ) ;;
		--pathspec=*)
			# shellcheck disable=SC2206
			pathspec=( ${o#*=} )
			;;
		--show-no-match) show_unmatched=y ;;
		--tag) show_tag=y ;;
		--print)   print_matches=y ;;
		--print=*) print_matches=y; re=${o*=} ;;
		--patch-id) print_patch_id=y ;;
		--update-gears) update_gears=y ;;
		--) echo >&2 "Perhaps, you need to use --pathspec="; exit 1 ;;
		--grep=*)  re=${o#*=} ;;&
		-[SG]*)    re=${o#-?} ;;&
		*) set -- "$@" "$o"
	esac
done

if [ -v update_gears ]; then
	git remote | grep -P '^gears/\d\.\d+' | sort -V |
		while read -r remote; do
			(set -x; git fetch "$remote" --tags)
		done
	exit 0
fi

if [[ $* == [A-Z]* ]]; then
	echo >&2 "Error: Perhaps, run: $(basename "$0") -G'$*'"
	exit 1
fi

[ -v pathspec ] && pathspec=(-- "${pathspec[@]}")

echo >&2 ":: git log $* ${pathspec[*]}"
while read -r br; do
	printf -v prefix '%-30s ' "${br#gears/}"
	if [ -v show_tag ]; then
		tag=$(git tag --points-at "$br" 'kernel-image-*' | head -1)
		tag=${tag#kernel-image-}
		tag=${tag%%-alt*}
		printf -v tag '%-20s' "[$tag]"
		prefix+="$tag "
	fi
	shopt -s lastpipe
	unset matched
	git log --oneline --format='%h %cd - %s (%an)' --date=short "$@" "$br" "${pathspec[@]}" |
	while read -r h a; do
		matched=y
		patch_id=
		if [ -v print_patch_id ]; then
			patch_id=$(git show "$h" | git patch-id)
			[ -n "$patch_id" ] && patch_id="<${patch_id:0:5}> "
		fi
		printf -- '%s %s %s\n' "$prefix" "$patch_id$h" "$a"
		[[ -v print_matches ]] &&
			git show -p "$h" | grep -H --label="  $prefix" --color -Pe "$re" || :
	done
	if [[ -v show_unmatched && ! -v matched ]]; then
		ts=$(git show -s --date=short --format=%cd "$br")
		printf '%s No match (%s)\n' "$prefix" "$ts"
	fi
done < <(list_branches)

